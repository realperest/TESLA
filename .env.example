PORT=3000
BASE_URL=http://localhost:3000

# Google OAuth - https://console.cloud.google.com adresinden alınır
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# JWT imzalama için rastgele güçlü bir string
JWT_SECRET=change_this_to_a_long_random_secret_string_at_least_64_chars

# Session cookie adı
COOKIE_NAME=tesla_tv_session
