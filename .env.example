PORT=3000
BASE_URL=http://localhost:3000

# Canlıda kanonik site (https://acilsusam.net). Railway *.up.railway.app ile girilirse tarayıcı buraya yönlendirilir.
# İsteğe bağlı: BASE_URL dışında izin verilen ek host (ör. www): ALLOWED_HOSTS=www.acilsusam.net

# Google OAuth - https://console.cloud.google.com adresinden alınır
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# JWT imzalama için rastgele güçlü bir string
JWT_SECRET=change_this_to_a_long_random_secret_string_at_least_64_chars

# Session cookie adı
COOKIE_NAME=tesla_tv_session

# Google Haritalar — Maps Embed API (Yol tarifi iframe). OAuth anahtarından farklıdır.
# Cloud Console: APIs & Services > Maps Embed API etkin + API anahtarı > HTTP referrer: http://localhost:3000/*
GOOGLE_MAPS_EMBED_API_KEY=

# YouTube (yt-dlp) — "bot" hatasina karsi Netscape cookies.txt. Repoya ekleme; Railway Secret/volume ile verin.
# YOUTUBE_COOKIES_FILE=/path/to/youtube-cookies.txt
